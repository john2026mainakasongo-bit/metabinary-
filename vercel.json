{
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/register", "destination": "/index.html" },
    { "source": "/trading-page", "destination": "/trading-page.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "trailingSlash": false
}
